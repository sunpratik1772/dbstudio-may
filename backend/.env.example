# ─────────────────────────────────────────────────────────────────
#  dbSherpa backend environment — template
# ─────────────────────────────────────────────────────────────────
#  Copy this file to `backend/.env` and fill in the values.
#  `.env` is gitignored; this `.env.example` is the checked-in template.
#
#    cp backend/.env.example backend/.env
#    $EDITOR backend/.env
#
# ─────────────────────────────────────────────────────────────────


# Required for Copilot + narrative section summaries.
# Get one from https://ai.google.dev (click "Get API key").
GEMINI_API_KEY=your-gemini-api-key-here


# Optional — override the directory xlsx reports are written to.
# Default is `backend/output/`. On Cloud Run, we set this to
# `/tmp/dbsherpa` because only /tmp is writable.
# DBSHERPA_OUTPUT_DIR=/tmp/dbsherpa
