{
  "schema_version": "1.0",
  "workflow_id": "fx_fro_001",
  "name": "FX Front-Running Detection",
  "version": "1.0",
  "description": "Detects front-running behavior in FX spot trading \u2014 proprietary trades placed ahead of client orders to profit from anticipated price moves",
  "nodes": [
    {
      "id": "n01",
      "type": "ALERT_TRIGGER",
      "label": "Alert Trigger",
      "config": {
        "alert_fields": {
          "trader_id": "string",
          "book": "string",
          "alert_date": "date",
          "currency_pair": "string",
          "alert_id": "string"
        }
      }
    },
    {
      "id": "n02",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Client Orders",
      "config": {
        "source": "hs_client_order",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND order_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "output_name": "client_orders",
        "loop_over_books": false
      }
    },
    {
      "id": "n03",
      "type": "EXECUTION_DATA_COLLECTOR",
      "label": "Collect Proprietary Executions",
      "config": {
        "source": "hs_execution",
        "query_template": "trader_id:{context.trader_id} AND book:{context.book} AND exec_time:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z] AND trade_version:1",
        "output_name": "executions",
        "loop_over_books": false
      }
    },
    {
      "id": "n04",
      "type": "COMMS_COLLECTOR",
      "label": "Collect Communications",
      "config": {
        "query_template": "user:{context.trader_id} AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "keywords": [
          "fix",
          "benchmark",
          "front-run",
          "ahead",
          "before the move",
          "WM fix",
          "cover",
          "rotate",
          "push through",
          "client order",
          "step-out"
        ],
        "output_name": "comms_data"
      }
    },
    {
      "id": "n05",
      "type": "MARKET_DATA_COLLECTOR",
      "label": "Collect EBS Tick Data",
      "config": {
        "source": "EBS",
        "query_template": "symbol:{context.currency_pair} AND timestamp:[{context.alert_date}T00:00:00Z TO {context.alert_date}T23:59:59Z]",
        "output_name": "market_data"
      }
    },
    {
      "id": "n06",
      "type": "FEATURE_ENGINE",
      "label": "Enrich Executions",
      "config": {
        "input_name": "executions",
        "output_name": "executions_enriched",
        "operations": [
          {"op": "derive_signed_notional"}
        ]
      }
    },
    {
      "id": "n07",
      "type": "SIGNAL_CALCULATOR",
      "label": "FRO Signal \u2014 Price Move Detection",
      "config": {
        "mode": "configure",
        "signal_type": "FRONT_RUNNING",
        "input_name": "executions_enriched",
        "output_name": "signals",
        "params": {
          "window_minutes": 5,
          "price_move_threshold": 0.0003
        }
      }
    },
    {
      "id": "n08",
      "type": "DECISION_RULE",
      "label": "Disposition Router",
      "config": {
        "input_name": "signals",
        "flag_count_expr": "flag_count > 0",
        "escalate_threshold": 5,
        "review_threshold": 1,
        "output_branches": {
          "ESCALATE": "escalate_branch",
          "REVIEW": "review_branch",
          "DISMISS": "dismiss_branch"
        }
      }
    },
    {
      "id": "n09",
      "type": "DATA_HIGHLIGHTER",
      "label": "Highlight Signal Rows",
      "config": {
        "input_name": "signals",
        "output_name": "signals_highlighted",
        "rules": [
          {
            "condition": "_signal_flag == True",
            "colour": "#FF4444",
            "label": "FRO SIGNAL"
          },
          {
            "condition": "side == 'BUY'",
            "colour": "#90EE90",
            "label": "BUY"
          },
          {
            "condition": "side == 'SELL'",
            "colour": "#87CEEB",
            "label": "SELL"
          }
        ]
      }
    },
    {
      "id": "n10",
      "type": "SECTION_SUMMARY",
      "label": "Trade Analysis Section",
      "config": {
        "section_name": "trade_analysis",
        "input_name": "signals",
        "field_bindings": [
          {
            "field": "exec_quantity",
            "agg": "sum"
          },
          {
            "field": "exec_price",
            "agg": "mean"
          },
          {
            "field": "venue",
            "agg": "nunique"
          },
          {
            "field": "signed_notional",
            "agg": "sum"
          }
        ],
        "llm_prompt_template": "You are a senior financial surveillance analyst.\n\nAnalyse the following FX execution statistics for potential front-running behavior:\n\nTrader: {trader_id}\nCurrency Pair: {currency_pair}\nDisposition: {disposition}\n\nStatistics:\n{stats}\n\nWrite a focused 2-paragraph analysis of the trading pattern, referencing specific numbers."
      }
    },
    {
      "id": "n11",
      "type": "SECTION_SUMMARY",
      "label": "Communications Analysis Section",
      "config": {
        "section_name": "comms_analysis",
        "input_name": "comms_data",
        "field_bindings": [
          {
            "field": "display_post",
            "agg": "count"
          },
          {
            "field": "event_type",
            "agg": "nunique"
          },
          {
            "field": "_keyword_hit",
            "agg": "sum"
          }
        ],
        "llm_prompt_template": "You are a senior financial surveillance analyst.\n\nReview the following communications metadata for a trader under investigation:\n\nTrader: {trader_id}\nDisposition: {disposition}\n\nStatistics:\n{stats}\n\nWrite a focused 2-paragraph summary of communication patterns and any concerning language."
      }
    },
    {
      "id": "n12",
      "type": "CONSOLIDATED_SUMMARY",
      "label": "Executive Summary",
      "config": {}
    },
    {
      "id": "n13",
      "type": "REPORT_OUTPUT",
      "label": "Generate Excel Report",
      "config": {
        "output_path": "output/fx_fro_report.xlsx",
        "tabs": [
          {
            "name": "Client Orders",
            "dataset": "client_orders",
            "include_highlights": true
          },
          {
            "name": "Executions",
            "dataset": "executions_enriched",
            "include_highlights": true
          },
          {
            "name": "Signals",
            "dataset": "signals",
            "include_highlights": true
          },
          {
            "name": "Communications",
            "dataset": "comms_data",
            "include_highlights": true
          },
          {
            "name": "Market Data (EBS)",
            "dataset": "market_data",
            "include_highlights": false
          }
        ]
      }
    }
  ],
  "edges": [
